# Copy to .env.local and fill in. Required for the AI chatbot to work.
# Get a key at https://console.groq.com (free tier available)
GROQ_API_KEY=gsk_...

# Optional — model the chatbot uses. Defaults to Llama 3.3 70B (fastest).
# Other options: llama-3.1-70b-versatile, gemma-2-9b-it
# See https://console.groq.com/docs/models for full list
# CHAT_MODEL=llama-3.1-70b-versatile
